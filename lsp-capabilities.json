{
  "schema": "OpenQCLspCapabilities",
  "version": 1,
  "id": "pyatb-lsp",
  "software": "pyatb",
  "displayName": "PyATB",
  "languageId": "pyatb",
  "executable": "pyatb-lsp",
  "defaultBranch": "main",
  "filePatterns": [
    "*.pyatb.py",
    "run_pyatb.py"
  ],
  "maturity": "stable",
  "blockingPolicy": {
    "mode": "blocking",
    "description": "Error diagnostics block run-gate and Bohrium submission until resolved."
  },
  "capabilities": [
    "agent-envelope",
    "agent-json-cli",
    "blocking-gate",
    "completion",
    "context",
    "diagnostic-engine-v1",
    "diagnostics",
    "fix-placeholder",
    "fix-preview",
    "hover",
    "llm-wiki",
    "manifest",
    "openqc-context",
    "output-log-diagnostics",
    "rich-diagnostics",
    "routing",
    "source-provenance",
    "symbols"
  ],
  "agentCli": {
    "command": "pyatb-lsp-tool",
    "operations": [
      "capabilities",
      "check",
      "context",
      "complete",
      "hover",
      "symbols",
      "fix"
    ],
    "jsonFormat": true,
    "failOnBlocking": true
  },
  "diagnosticSchema": "diagnostics/diagnostic-engine-v1.schema.json",
  "wikiPaths": {
    "plan": "docs/LLM-WIKI-PLAN.md",
    "rawAssets": "raw/assets",
    "entities": "wiki/entities",
    "concepts": "wiki/concepts",
    "synthesis": "wiki/synthesis",
    "index": "index.md",
    "log": "log.md"
  },
  "fixturePaths": {
    "valid": [
      "tests/fixtures/valid",
      "test/fixtures/valid"
    ],
    "invalid": [
      "tests/fixtures/invalid",
      "test/fixtures/invalid"
    ],
    "logs": [
      "tests/fixtures/logs",
      "test/fixtures/logs"
    ]
  },
  "outputLogPatterns": [
    "pyatb.log",
    "*.pyatb.log",
    "*.pyatb.out"
  ],
  "openqc": {
    "registryId": "pyatb-lsp",
    "repoName": "pyatb-lsp",
    "contextContract": "DSLAuthoringContext",
    "diagnosticEnvelope": "DiagnosticEnvelope/v1"
  },
  "sourceProvenance": [
    {
      "id": "pyatb-official-docs",
      "kind": "official_docs",
      "label": "PyATB documentation",
      "url": "https://pyatb.github.io/pyatb/",
      "license": "see upstream PyATB repository"
    },
    {
      "id": "pyatb-input-reference",
      "kind": "local_mirror",
      "label": "PyATB input reference",
      "path": "raw/assets/pyatb-input-reference.md",
      "upstream_url": "https://pyatb.github.io/pyatb/user_guide/input.html"
    },
    {
      "id": "pyatb-examples",
      "kind": "local_mirror",
      "label": "PyATB examples",
      "path": "raw/assets/pyatb-examples.md",
      "upstream_url": "https://pyatb.github.io/pyatb/user_guide/examples.html"
    },
    {
      "id": "pyatb-abacus-integration",
      "kind": "local_mirror",
      "label": "PyATB ABACUS integration",
      "path": "raw/assets/pyatb-abacus-integration.md",
      "upstream_url": "https://pyatb.github.io/pyatb/user_guide/abacus.html"
    },
    {
      "id": "pyatb-transport-implementation",
      "kind": "local_mirror",
      "label": "PyATB transport implementation notes",
      "path": "raw/assets/pyatb-transport-implementation.md",
      "upstream_url": "https://pyatb.github.io/pyatb/"
    },
    {
      "id": "pyatb-lsp-diagnostic-engine",
      "kind": "repo_contract",
      "label": "Diagnostic Engine v1 contract",
      "path": "raw/assets/DIAGNOSTIC_ENGINE_V1.md"
    }
  ],
  "pipeline": [
    "official-docs-fetch",
    "raw-assets-index",
    "wiki-entities",
    "structured-schema-rules",
    "source-provenance",
    "tests",
    "lsp-runtime"
  ],
  "ruleIndex": "src/pyatb_lsp/schema/pyatb_rules.json",
  "provenanceUpdatedAt": "2026-06-15T09:22:49+00:00"
}
